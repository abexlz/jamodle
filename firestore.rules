rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;

      match /private/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /friendRequests/{requestId} {
      function partsMatch() {
        return request.auth != null
          && (requestId.split('_')[0] == request.auth.uid
            || requestId.split('_')[1] == request.auth.uid);
      }
      function isParty() {
        return request.auth != null
          && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);
      }
      allow get: if partsMatch();
      allow list: if isParty();
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && request.resource.data.fromName is string
        && request.resource.data.toName is string
        && requestId == request.resource.data.fromUid + '_' + request.resource.data.toUid;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toUid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid;
      allow delete: if request.auth != null
        && resource.data.status == 'pending'
        && (
          request.auth.uid == resource.data.fromUid
          || request.auth.uid == resource.data.toUid
        );
    }

    match /dailyResults/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && docId == request.resource.data.date + '_' + request.auth.uid;
    }

    match /matches/{matchId} {
      function isMatchParty() {
        return request.auth != null
          && (request.auth.uid == resource.data.player1Uid
            || request.auth.uid == resource.data.player2Uid);
      }

      function isMatchPartyOnWrite() {
        return request.auth != null
          && (request.auth.uid == request.resource.data.player1Uid
            || request.auth.uid == request.resource.data.player2Uid);
      }

      function progressUnchanged(key) {
        let before = resource.data.get(key, {});
        let after = request.resource.data.get(key, {});
        return after.get('guessCount', 0) == before.get('guessCount', 0)
          && after.get('finished', false) == before.get('finished', false)
          && after.get('won', false) == before.get('won', false);
      }

      function opponentProgressUnchanged() {
        return (request.auth.uid == resource.data.player1Uid
            && progressUnchanged('player2Progress'))
          || (request.auth.uid == resource.data.player2Uid
            && progressUnchanged('player1Progress'));
      }

      function isDeclineUpdate() {
        return request.resource.data.status == 'declined'
          && request.resource.data.declinedByUid == request.auth.uid
          && request.resource.data.player1Uid == resource.data.player1Uid
          && request.resource.data.player2Uid == resource.data.player2Uid;
      }

      function isAbandonUpdate() {
        return (resource.data.status == 'pending'
            || resource.data.status == 'ready'
            || resource.data.status == 'active')
          && request.resource.data.status == 'abandoned'
          && request.resource.data.abandonedByUid == request.auth.uid
          && request.resource.data.player1Uid == resource.data.player1Uid
          && request.resource.data.player2Uid == resource.data.player2Uid
          && request.resource.data.winnerUid == (
            request.auth.uid == resource.data.player1Uid
              ? resource.data.player2Uid
              : resource.data.player1Uid
          )
          && progressUnchanged('player1Progress')
          && progressUnchanged('player2Progress');
      }

      function isRelatedWordsMatchUpdate() {
        return resource.data.gameType == 'related-words'
          && request.resource.data.gameType == 'related-words'
          && request.resource.data.player1Uid == resource.data.player1Uid
          && request.resource.data.player2Uid == resource.data.player2Uid
          && resource.data.status in ['ready', 'active']
          && request.resource.data.status in ['active', 'done'];
      }

      allow get: if isMatchParty();
      allow list: if isMatchParty();

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.player1Uid
        && request.resource.data.player2Uid is string
        && request.resource.data.player1Uid != request.resource.data.player2Uid
        && request.resource.data.target is string
        && request.resource.data.player1Name is string
        && request.resource.data.player2Name is string
        && (
          (request.resource.data.status == 'pending'
            && request.resource.data.player1Ready == true
            && request.resource.data.player2Ready == false)
          || (request.resource.data.status == 'ready'
            && request.resource.data.player1Ready == true
            && request.resource.data.player2Ready == true
            && request.resource.data.rematchFrom is string
            && request.resource.data.rematchFrom.size() > 0)
        )
        && (
          (request.resource.data.get('gameType', 'wordle') == 'wordle'
            && request.resource.data.wordLength in [2, 3])
          || (request.resource.data.gameType == 'korean-match'
            && request.resource.data.wordLength is int
            && request.resource.data.wordLength in [2, 3, 4, 5, 6])
          || (request.resource.data.gameType == 'related-words'
            && request.resource.data.chainId is string
            && request.resource.data.raceTarget is int
            && request.resource.data.raceTarget >= 1
            && request.resource.data.raceTarget <= 50
            && request.resource.data.wordLength is int)
        );

      function isRematchLobbyUpdate() {
        return resource.data.status == 'done'
          && request.resource.data.status == 'done'
          && request.resource.data.player1Uid == resource.data.player1Uid
          && request.resource.data.player2Uid == resource.data.player2Uid
          && request.resource.data.winnerUid == resource.data.winnerUid
          && request.resource.data.get('target', '') == resource.data.get('target', '')
          && request.resource.data.get('gameType', 'wordle') == resource.data.get('gameType', 'wordle')
          && request.resource.data.get('wordLength', 0) == resource.data.get('wordLength', 0)
          && request.resource.data.get('chainId', '') == resource.data.get('chainId', '')
          && request.resource.data.get('playMode', '') == resource.data.get('playMode', '')
          && progressUnchanged('player1Progress')
          && progressUnchanged('player2Progress');
      }

      allow update: if request.auth != null
        && isMatchParty()
        && isMatchPartyOnWrite()
        && (opponentProgressUnchanged()
          || isDeclineUpdate()
          || isAbandonUpdate()
          || isRelatedWordsMatchUpdate()
          || isRematchLobbyUpdate());

      allow delete: if request.auth != null
        && resource.data.status == 'pending'
        && (
          request.auth.uid == resource.data.player2Uid
          || request.auth.uid == resource.data.player1Uid
        );
    }

    match /wordChainMatches/{matchId} {
      function isWordChainParty() {
        return request.auth != null
          && (request.auth.uid == resource.data.player1Uid
            || request.auth.uid == resource.data.player2Uid);
      }

      function isWordChainPartyOnWrite() {
        return request.auth != null
          && (request.auth.uid == request.resource.data.player1Uid
            || request.auth.uid == request.resource.data.player2Uid);
      }

      allow get: if isWordChainParty();
      allow list: if isWordChainParty();

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.player1Uid
        && request.resource.data.player2Uid is string
        && request.resource.data.player1Uid != request.resource.data.player2Uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.player1Name is string
        && request.resource.data.player2Name is string
        && request.resource.data.currentTurnUid is string
        && request.resource.data.usedWords is list;

      allow update: if request.auth != null
        && isWordChainParty()
        && isWordChainPartyOnWrite()
        && request.resource.data.player1Uid == resource.data.player1Uid
        && request.resource.data.player2Uid == resource.data.player2Uid;

      allow delete: if request.auth != null
        && resource.data.status == 'waiting'
        && (
          request.auth.uid == resource.data.player2Uid
          || request.auth.uid == resource.data.player1Uid
        );
    }
  }
}
